# Copy to .env and fill in. The app runs without any LLM key (mock evaluator/simulator,
# local hash embeddings) but real AI features need at least one provider key.

# SQLite database: data/app.db (persist ./data in production).

# LLM providers — set one or both. Active provider/model is chosen in Admin → Settings.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# First admin account created by npm run seed / Docker startup.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# API/server port (the Vite client dev server proxies /api here)
API_PORT=4000
