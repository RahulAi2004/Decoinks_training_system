{
  "name": "decoinks-intern-trainer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Decoinks Intern Trainer & Evaluation Portal — train, practise, auto-evaluate, and certify sales interns.",
  "scripts": {
    "dev": "concurrently -k -n server,client \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "ingest": "node server/ingest.js",
    "import:real-chats": "node server/import-real-chats.js",
    "import:customer-library": "node server/import-customer-library.js --rebuild",
    "seed": "node server/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.11"
  }
}
